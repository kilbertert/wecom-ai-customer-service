{
  "name": "wecom-ai-customer-service",
  "version": "1.0.0",
  "description": "Enterprise WeChat AI Customer Service System",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "skill": "node dist/skill-index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/database.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/database.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "axios": "^1.5.0",
    "ws": "^8.14.2",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "turndown": "^7.1.2",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "winston": "^3.10.0",
    "uuid": "^9.0.0",
    "moment": "^2.29.4",
    "qrcode": "^1.5.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/ws": "^8.5.5",
    "@types/multer": "^1.4.7",
    "@types/uuid": "^9.0.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/node": "^20.5.0",
    "typescript": "^5.1.6",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.47.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.5"
  }
