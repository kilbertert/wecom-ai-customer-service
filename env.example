# ========================================
# 微信客服配置 (必需)
# ========================================

# 企业微信CorpID - 从企业微信管理后台获取
WECHAT_CORP_ID=wwe23eb3735710f8dc

# 企业微信Secret - 从企业微信管理后台获取
WECHAT_CORP_SECRET=vq8j5OtUETE4-aie8UqBla6O9hQ-9JGaWPLTQ91JB5I

# 微信客服Token - 自定义字符串，用于验证消息签名
WECHAT_KF_TOKEN=OCmjYUSjJhpsKUDpneDdWhoI

# 微信客服EncodingAESKey - 自定义字符串，用于消息加密
WECHAT_ENCODING_AES_KEY=AujPZkqIfghgcqNUQKoFlmmORPekMWhRovTAUBnKfIb

# 回调URL基础地址 - 部署服务的域名
WECHAT_CALLBACK_BASE_URL=https://89184qkwj686.vicp.fun

# 指定客服ID (可选) - 只处理来自指定客服的消息
# 如果为空，则处理所有客服的消息
# WECHAT_ALLOWED_OPEN_KFID=kfc82c20e0d9c4d10a8

# ========================================
# Coze智能体配置 (必需)
# ========================================

# Coze API Token - 从Coze平台获取
COZE_API_TOKEN= pat_qHIVHTOKOv7PEAoBFULbh8sl8rnglTnbr6FGUvJoSR46nf9zWS9DKlLNwO0Gqg5C

# Coze工作流ID - 工作流发布后的ID
COZE_WORKFLOW_ID=7599886499640147968


# Coze API基础URL - 通常不需要修改
COZE_API_BASE_URL=https://api.coze.com

# ========================================
# Dify 智能体配置 (与 Coze 二选一,见 APP_AI_BACKEND)
# ========================================

# Dify API base — 国服/海外统一域名
# DIFY_API_BASE=https://api.dify.ai/v1

# Dify API Key — 形如 app-xxx
# DIFY_API_KEY=

# Dify workflow 输入变量名 — 与工作流"开始"节点保持一致
# DIFY_INPUT_TEXT=input_text
# DIFY_INPUT_IMAGE=input_img_id
# DIFY_INPUT_AUDIO=input_audio_id

# Dify 强制要求的 end-user 标识(WeChat 场景下会用 external_userid 覆盖)
# DIFY_END_USER_DEFAULT=wechat-default-user

# Dify 工作流超时(秒) — Dify 较 Coze 慢,默认 120s
# DIFY_WORKFLOW_TIMEOUT=120

# Dify 工作流文本输出变量名 — workflow 结束节点里设置的变量
# DIFY_OUTPUT_TEXT=output

# ========================================
# 应用配置 (可选)
# ========================================

# 应用密钥 - 用于安全签名，建议使用随机字符串
APP_SECRET_KEY=your_secret_key_here

# 调试模式 - 生产环境设为false
APP_DEBUG=false

# 服务器主机 - 0.0.0.0表示监听所有地址
APP_HOST=0.0.0.0

# 服务器端口
APP_PORT=8000

# AI 后端选择: "coze" (默认, 向后兼容) | "dify"
# 切换后需在对应小节 (上方 Coze / Dify) 填入对应凭据
APP_AI_BACKEND=coze